# Database URL (default: SQLite)
DATABASE_URL=sqlite+aiosqlite:///./fx_analytics.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/fx_analytics

# Server
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Artifacts directory
ARTIFACTS_DIR=./artifacts

# Optional: Alpha Vantage API key (not needed if using yfinance)
# ALPHA_VANTAGE_API_KEY=your_key_here

# OpenAI API key for AI-powered analysis (optional)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-mini
